# Amazon Associates / Creators API
# Provisional, non-sensitive values that can be configured before API credentials exist.
AMAZON_PARTNER_TAG=your-amazon-es-tag-21
AMAZON_MARKETPLACE=www.amazon.es
AMAZON_PRODUCT_API_PROVIDER=creators
AMAZON_SNAPSHOT_TTL_HOURS=24

# Creators API credentials — server-side/local only. Do not expose in client code.
# Fill only after Amazon Associates Central creates the CreatorsAPI application/credential.
AMAZON_CREATORS_CREDENTIAL_ID=
AMAZON_CREATORS_CREDENTIAL_SECRET=
AMAZON_CREATORS_CREDENTIAL_VERSION=

# Optional Creators API overrides if Amazon assigns explicit values.
# AMAZON_CREATORS_TOKEN_ENDPOINT=
# AMAZON_CREATORS_API_BASE=https://creatorsapi.amazon
# AMAZON_CREATORS_SCOPE=

# PA API legacy only — do not use for new integration unless account access is explicitly confirmed.
# AMAZON_PRODUCT_API_PROVIDER=paapi
# AMAZON_PAAPI_ACCESS_KEY=
# AMAZON_PAAPI_SECRET_KEY=
# AMAZON_PAAPI_HOST=webservices.amazon.es
# AMAZON_PAAPI_REGION=eu-west-1
