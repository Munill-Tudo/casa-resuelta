---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles } from '../../data/articles';
const brands = Array.from(new Set(articles.flatMap(a => a.products.map(p => p.name.split(' ')[0].replace('De’Longhi','De’Longhi'))))).sort();
---
<BaseLayout title="Marcas" description="Marcas y fabricantes presentes en las comparativas de Con Buen Ojo.">
<section class="category-hero"><div class="container"><span class="eyebrow">Marcas</span><h1>Marcas incluidas en las comparativas</h1><p class="lead">Encuentra fabricantes presentes en nuestras guías para revisar alternativas dentro de cada categoría.</p></div></section>
<section class="section"><div class="container grid grid-3">{brands.map(b => <div class="card"><span class="pill">Marca</span><h3>{b}</h3><p>Marca mencionada en nuestras guías y comparativas de productos para casa.</p></div>)}</div></section>
</BaseLayout>
