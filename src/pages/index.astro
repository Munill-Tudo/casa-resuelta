---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../data/categories';
import { articles } from '../data/articles';
const top = articles.filter(a => a.priority === 'P1').slice(0, 10);
const featured = top[0];
const secondary = top.slice(1, 5);
const categoryList = categories.filter(c => !['hogar','deporte-casa','familia'].includes(c.slug));
---
<BaseLayout title="Con Buen Ojo" description="Comparativas y guías de compra para productos útiles de casa: hogar, cocina, climatización, limpieza, terraza, piscina, mascotas y teletrabajo.">
  <section class="market-hero">
    <div class="container hero-market-grid">
      <div class="hero-copy">
        <span class="eyebrow">Casa práctica · análisis editorial</span>
        <h1>Compara antes de comprar productos para casa.</h1>
        <p class="lead">Guías visuales, rankings y tablas claras para elegir ventiladores, robots, organizadores, luces solares, herramientas y productos útiles sin caer en rankings vacíos.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="/categorias/">Ver categorías</a>
          <a class="btn btn-secondary" href="/metodologia/">Cómo recomendamos</a>
        </div>
      </div>
      <aside class="hero-featured-card">
        <span class="deal-label">Guía destacada</span>
        <div class="hero-image">🌬️</div>
        <div class="store-line"><span>Con Buen Ojo</span><strong>Actualizado hoy</strong></div>
        <h2><a href={`/${featured.category}/${featured.slug}/`}>{featured.title}</a></h2>
        <p>{featured.description}</p>
        <div class="price-row"><strong>Comparativa P1</strong><span>Ranking + criterios + errores</span></div>
        <a class="btn btn-primary full" href={`/${featured.category}/${featured.slug}/`}>Leer análisis</a>
      </aside>
    </div>
  </section>

  <section class="section category-dock-section">
    <div class="container">
      <div class="section-head">
        <h2>Categorías populares</h2>
        <a href="/categorias/">Ver todas</a>
      </div>
      <div class="category-dock">
        {categoryList.slice(0, 11).map(c => <a class="category-tile" href={`/${c.slug}/`}><span>{c.icon}</span><strong>{c.name}</strong><small>{c.description}</small></a>)}
      </div>
    </div>
  </section>

  <section class="section deals-layout">
    <div class="container page-grid">
      <main>
        <div class="section-head tabs-head">
          <h2>Guías y comparativas recomendadas</h2>
          <div class="tabs"><span class="active">Destacadas</span><span>Populares</span><span>Nuevas</span></div>
        </div>
        <div class="deal-list">
          {top.map((a, i) => {
            const cat = categories.find(c => c.slug === a.category);
            return <a class="deal-card" href={`/${a.category}/${a.slug}/`}>
              <div class="deal-vote"><strong>{92 - i}</strong><span>score</span></div>
              <div class="deal-thumb">{cat?.icon ?? '🏠'}</div>
              <div class="deal-body">
                <div class="deal-meta"><span>{cat?.name}</span><span>{a.type}</span><span>{a.priority}</span></div>
                <h3>{a.title}</h3>
                <p>{a.description}</p>
                <div class="deal-tags"><span>Para quién sí/no</span><span>Tabla comparativa</span><span>Errores comunes</span></div>
              </div>
              <div class="deal-cta"><strong>{a.type === 'Ranking' ? 'Top opciones' : 'Guía clara'}</strong><span>Leer ahora</span></div>
            </a>;
          })}
        </div>
      </main>
      <aside class="sidebar">
        <div class="side-card testing-card">
          <h3>Reviews en las que puedes confiar</h3>
          <p>Inspirado en el modelo editorial de laboratorio: criterios visibles, comparación lado a lado, limitaciones y alternativas por caso de uso.</p>
          <ul>
            <li>Sin “mejor producto” universal.</li>
            <li>Sin chollos sin contexto.</li>
            <li>Con aviso afiliado claro.</li>
          </ul>
        </div>
        <div class="side-card popular-card">
          <h3>Más buscado</h3>
          {secondary.map(a => <a href={`/${a.category}/${a.slug}/`}><span>{a.type}</span>{a.title}</a>)}
        </div>
      </aside>
    </div>
  </section>

  <section class="section proof-band">
    <div class="container proof-grid">
      <div><strong>30</strong><span>URLs iniciales</span></div>
      <div><strong>53</strong><span>páginas en sitemap</span></div>
      <div><strong>14</strong><span>categorías base</span></div>
      <div><strong>100%</strong><span>transparencia afiliada</span></div>
    </div>
  </section>
</BaseLayout>
