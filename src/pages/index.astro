---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories } from '../data/categories';
import { articles } from '../data/articles';
const top = articles.filter(a => a.priority === 'P1').slice(0, 9);
---
<BaseLayout title="Casa Resuelta" description="Productos útiles, decisiones sencillas. Guías prácticas para elegir mejor productos de hogar, cocina, limpieza, climatización, terraza, piscina, mascotas y teletrabajo."><section class="hero"><div class="container"><span class="eyebrow">Nueva guía editorial de hogar práctico</span><h1>Productos útiles para casa, elegidos con criterio.</h1><p class="lead">Casa Resuelta ayuda a decidir sin perder horas entre rankings vacíos: comparativas claras, errores que evitar, para quién sí, para quién no y alternativas por presupuesto.</p><div class="hero-actions"><a class="btn btn-primary" href="/categorias/">Explorar categorías</a><a class="btn btn-secondary" href="/metodologia/">Cómo recomendamos</a></div></div></section><section class="section soft"><div class="container"><h2>No va de chollos. Va de resolver problemas de casa.</h2><p class="section-intro">Ordenar una cocina pequeña, dormir con calor, limpiar pelo de mascota, preparar una terraza o mejorar el teletrabajo: cada guía parte de un caso real de uso.</p><div class="grid grid-3"><div class="card"><h3>Para quién es</h3><p>Personas que quieren comprar con cabeza, entender límites y elegir según vivienda, presupuesto y frecuencia de uso.</p></div><div class="card"><h3>Para quién no es</h3><p>No somos una lista automática de ofertas ni prometemos “el mejor producto definitivo” sin contexto.</p></div><div class="card"><h3>Cómo monetiza</h3><p>Usamos enlaces afiliados de forma transparente. La comisión no debe sustituir el criterio editorial.</p></div></div></div></section><section class="section"><div class="container"><h2>Categorías principales</h2><p class="section-intro">La arquitectura sigue el SOP: hogar práctico como marca amplia, con verticales de alto potencial evergreen y estacional.</p><div class="grid grid-3">{categories.filter(c => !['hogar','deporte-casa','familia'].includes(c.slug)).map(c => <a class="card card-link" href={`/${c.slug}/`}><span class="badge">{c.icon} {c.name}</span><h3>{c.name}</h3><p>{c.description}</p></a>)}</div></div></section><section class="section soft"><div class="container"><h2>30 páginas iniciales publicadas</h2><p class="section-intro">La web arranca con el backlog mínimo del SOP: rankings, guías prácticas, comparativas y selección editorial.</p><div class="grid grid-3">{top.map(a => <a class="card card-link" href={a.url}><div class="meta"><span class="pill">{a.type}</span><span class="pill">{a.priority}</span></div><h3>{a.title}</h3><p>{a.description}</p></a>)}</div><p style="margin-top:24px"><a class="btn btn-secondary" href="/categorias/">Ver las 30 URLs</a></p></div></section><section class="section"><div class="container"><h2>Sistema editorial aplicado</h2><div class="score"><div><strong>30</strong><span>contenidos iniciales</span></div><div><strong>13</strong><span>categorías base</span></div><div><strong>100%</strong><span>con aviso afiliado</span></div><div><strong>SEO</strong><span>sitemap + URLs limpias</span></div></div></div></section></BaseLayout>