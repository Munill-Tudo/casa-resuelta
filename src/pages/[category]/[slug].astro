---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateNotice from '../../components/AffiliateNotice.astro';
import { categories } from '../../data/categories';
import { articles } from '../../data/articles';
import { productUrl } from '../../data/products';

export function getStaticPaths() {
  return articles.map(article => ({
    params: { category: article.category, slug: article.slug },
    props: { article, category: categories.find(c => c.slug === article.category) }
  }));
}

const { article, category: categoryMaybe } = Astro.props;
const category = categoryMaybe ?? categories.find(c => c.slug === article.category)!;
const related = articles.filter(a => a.category === article.category && a.slug !== article.slug).slice(0, 3);
const editorial = (article as any).editorial ?? {};
const decisionText = editorial.quickDecision ?? 'Empieza por la comparativa y abre Amazon solo para confirmar precio, stock y vendedor antes de comprar.';
const verdictTitle = editorial.verdictTitle ?? 'Tres opciones para comparar sin perder tiempo.';
const verdictText = editorial.verdictText ?? `Para ${article.keyword}, compara ${article.products[0]?.name} si buscas una opción equilibrada, ${article.products[1]?.name} si quieres ajustar el presupuesto y ${article.products[2]?.name} si necesitas más prestaciones.`;
const selectionIntro = editorial.selectionIntro ?? 'La selección prioriza productos útiles para el uso indicado, diferencias claras entre modelos y limitaciones que conviene conocer antes de comprar. La idea es que puedas descartar rápido lo que no encaja contigo.';
const criteria: [string, string][] = editorial.criteria ?? [
  ['Uso principal', 'Qué necesidad resuelve y en qué tipo de casa encaja mejor.'],
  ['Punto fuerte', 'La razón práctica por la que cada producto merece estar en la comparativa.'],
  ['Punto débil', 'La limitación que debes revisar antes de decidir.'],
  ['Alternativa adecuada', 'Cuándo elegir una opción sencilla, calidad-precio o más completa.']
];
const mistakes: string[] = editorial.mistakes ?? [
  'Elegir solo por precio sin revisar medidas, ruido, consumo o mantenimiento.',
  'Comprar la opción premium si el uso será ocasional.',
  'No comprobar condiciones de devolución, garantía, disponibilidad y repuestos.',
  'Confundir producto viral con producto realmente útil para tu casa.'
];
const honestVerdict = editorial.honestVerdict ?? 'La mejor compra será la que resuelva tu caso con el menor coste total: precio, espacio, mantenimiento y frecuencia de uso. Si el problema es ocasional, compara primero una alternativa sencilla o de coste contenido. Si lo vas a usar a diario, una opción más completa puede compensar.';
const conversion = editorial.conversion ?? {};
const buyIf: string[] = conversion.buyIf ?? [
  `Tu caso coincide con ${article.caseUse.toLowerCase()}`,
  `El producto recomendado encaja con tus medidas, frecuencia de uso y forma de guardar o mantenerlo.`,
  'Vas a comprobar precio, vendedor, envío y condiciones actuales antes de comprar.'
];
const doNotBuyIf: string[] = conversion.doNotBuyIf ?? [
  'Solo lo necesitas una vez o puedes resolverlo con algo que ya tienes.',
  'No has medido el espacio disponible o no tienes claro dónde se usará.',
  'La principal limitación del producto recomendado es importante para tu caso.'
];
const amazonChecks: string[] = conversion.amazonChecks ?? [
  'Precio actualizado y posibles cupones o variaciones por vendedor.',
  'Stock, plazo de entrega y política de devolución vigente.',
  'Medidas, compatibilidad, recambios y condiciones de garantía.'
];
const primaryProduct = article.products[0];
---
<BaseLayout title={article.title} description={article.description} canonical={article.url}>
  <div class="container article-shell">
    <article class="article review-page">
      <div class="breadcrumbs"><a href="/">Inicio</a> / <a href={`/${category.slug}/`}>{category.name}</a> / {article.title}</div>
      <div class="review-kicker"><span>{category.icon} {category.name}</span><span>{article.type}</span><span>Actualizado: {article.updatedAt}</span></div>
      <h1>{article.title}</h1>
      <p class="lead">{article.caseUse}</p>

      <section class="article-action-panel" aria-label="Acciones rápidas">
        <div>
          <strong>Decisión rápida</strong>
          <span>{decisionText}</span>
        </div>
        <a class="btn btn-primary" href="#comparativa">Ver comparativa</a>
        <a class="btn btn-secondary" href={productUrl(article.products[0]?.name)}>Ficha del recomendado</a>
      </section>

      <section class="verdict-box">
        <div>
          <span class="eyebrow">Veredicto rápido</span>
          <h2>{verdictTitle}</h2>
          <p>{verdictText}</p>
        </div>
        <div class="verdict-badge"><strong>Top 3</strong><span>selección recomendada</span></div>
      </section>

      <h2 id="resumen">Top 3 recomendado</h2>
      <div class="top3-grid">
        {article.products.map((p, i) => <a class="top3-card" href={productUrl(p.name)}>
          <span>{i === 0 ? 'Mejor global' : i === 1 ? 'Calidad-precio' : 'Alternativa premium'}</span>
          <strong>{p.name}</strong>
          <small>{p.bestFor}</small>
        </a>)}
      </div>

      <h2 id="comparativa">Comparativa rápida</h2>
      <div class="product-rank-list">
        {article.products.map((p, i) => <div class="product-rank-card">
          <div class="rank-number">#{i + 1}</div>
          <div class="product-visual">{category.icon}</div>
          <div class="product-copy">
            <div class="deal-meta"><span>{p.bestFor}</span><span>{p.price}</span></div>
            <h3><a href={productUrl(p.name)}>{p.name}</a></h3>
            <p>{p.strength}</p>
            <small>Punto débil: {p.limitation}</small>
          </div>
          <div class="product-actions"><a class="btn btn-secondary" href={productUrl(p.name)}>Ver análisis</a><a class="btn btn-primary" href={p.url} rel="sponsored nofollow noopener" target="_blank">{p.cta ?? 'Ver precio en Amazon'}</a></div>
        </div>)}
      </div>
      <p class="microcopy">No publicamos precios fijos para evitar datos desactualizados. Antes de comprar, revisa en Amazon el precio vigente, stock, vendedor, envío y condiciones.</p>

      <section class="purchase-fit-panel" id="decision-compra">
        <div class="purchase-fit-header">
          <span class="eyebrow">Decisión de compra</span>
          <h2>Cuándo comprar y cuándo esperar</h2>
          <p>Usa este bloque como filtro final antes de abrir Amazon: evita compras impulsivas y confirma solo lo que encaja con tu casa.</p>
        </div>
        <div class="purchase-fit-grid">
          <div class="purchase-fit-card yes"><strong>Comprar si</strong><ul>{buyIf.map(item => <li>{item}</li>)}</ul></div>
          <div class="purchase-fit-card no"><strong>Mejor no comprar si</strong><ul>{doNotBuyIf.map(item => <li>{item}</li>)}</ul></div>
          <div class="purchase-fit-card check"><strong>Al abrir Amazon revisa</strong><ul>{amazonChecks.map(item => <li>{item}</li>)}</ul></div>
        </div>
        {primaryProduct && <div class="conversion-cta">
          <div><strong>Si encaja contigo:</strong><span>lee primero la ficha de {primaryProduct.name} y después confirma precio actualizado, stock y vendedor en Amazon.</span></div>
          <a class="btn btn-secondary" href={productUrl(primaryProduct.name)}>Ver ficha recomendada</a>
          <a class="btn btn-primary" href={primaryProduct.url} rel="sponsored nofollow noopener" target="_blank">Comprobar en Amazon</a>
        </div>}
      </section>

      <h2 id="seleccion">Qué hemos tenido en cuenta</h2>
      <p>{selectionIntro}</p>
      <div class="criteria-grid">
        {criteria.map(([label, text]) => <div><strong>{label}</strong><span>{text}</span></div>)}
      </div>

      <h2 id="perfil">Recomendaciones por perfil</h2>
      {article.products.map(p => <section class="profile-block"><h3><a href={productUrl(p.name)}>{p.name}</a></h3><p><strong>Para quién sí:</strong> {p.bestFor}; usuarios que quieren resolver la necesidad principal sin comprar más de lo necesario.</p><p><strong>Para quién no:</strong> si esta limitación es importante para ti: {p.limitation}</p><div class="profile-actions"><a href={productUrl(p.name)}>Leer ficha</a><a href={p.url} rel="sponsored nofollow noopener" target="_blank">Ver precio actualizado</a></div></section>)}

      <h2 id="errores">Errores comunes al comprar</h2>
      <ul class="check-list">
        {mistakes.map(item => <li>{item}</li>)}
      </ul>

      <h2 id="veredicto">Veredicto honesto</h2>
      <p>{honestVerdict}</p>
      <AffiliateNotice />

      {related.length > 0 && <section class="related"><h2>También puede interesarte</h2><div class="grid grid-3">{related.map(a => <a class="card card-link" href={`/${a.category}/${a.slug}/`}><span class="pill">{a.type}</span><h3>{a.title}</h3><p>{a.description}</p></a>)}</div></section>}
    </article>
    <aside class="toc">
      <h3>En esta guía</h3>
      <a href="#resumen">Top 3 recomendado</a>
      <a href="#comparativa">Comparativa rápida</a>
      <a href="#decision-compra">Comprar o esperar</a>
      <a href="#seleccion">Qué miramos</a>
      <a href="#perfil">Por perfil</a>
      <a href="#errores">Errores comunes</a>
      <a href="#veredicto">Veredicto</a>
    </aside>
  </div>
</BaseLayout>
